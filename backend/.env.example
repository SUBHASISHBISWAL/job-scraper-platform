# Database Configuration
# Optional: Provide a PostgreSQL URL. If left empty or connection fails, the system automatically falls back to a local SQLite database (jobscraper.db)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# AI Configuration
# Optional: Provide your Gemini API key to enable advanced AI answers. If left empty, a robust local rule-based system will be used
# GEMINI_API_KEY=your_gemini_api_key_here
